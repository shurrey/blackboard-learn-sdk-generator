{
  "name": "{{langConfig.packageName}}",
  "version": "{{metadata.version}}",
  "description": "TypeScript/JavaScript SDK for the Blackboard Learn REST API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check src/",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "prettier": "^3.3.0"
  },
  "keywords": [
    "blackboard",
    "learn",
    "lms",
    "sdk",
    "rest-api",
    "education"
  ],
  "license": "{{metadata.license}}",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackboard/learn-typescript"
  }
}
