import { describe, it, expect, vi, beforeEach } from 'vitest';
import { {{PascalCase resource.name}}Resource } from '../src/resources/{{resource.name}}.js';
import type { HttpClient } from '../src/http-client.js';

describe('{{PascalCase resource.name}}Resource', () => {
  let mockClient: HttpClient;
  let resource: {{PascalCase resource.name}}Resource;

  beforeEach(() => {
    mockClient = {
      get: vi.fn().mockResolvedValue({}),
      post: vi.fn().mockResolvedValue({}),
      put: vi.fn().mockResolvedValue({}),
      patch: vi.fn().mockResolvedValue({}),
      delete: vi.fn().mockResolvedValue(undefined),
      rawRequest: vi.fn().mockResolvedValue({ ok: true, json: () => ({ results: [], paging: null }) }),
      downloadFile: vi.fn().mockResolvedValue({ data: new ArrayBuffer(0), contentType: 'application/octet-stream' }),
      uploadFile: vi.fn().mockResolvedValue({}),
    } as any;
    resource = new {{PascalCase resource.name}}Resource(mockClient);
  });

  it('can be instantiated', () => {
    expect(resource).toBeDefined();
  });

{{#each resource.methods}}
  {{#unless paginated}}
  {{#isUpload this}}
  it('{{camelCase name}} sends upload request', async () => {
    const file = new Blob(['test']);
    await resource.{{camelCase name}}({{#each pathParams}}'test-id', {{/each}}file);
    expect(mockClient.uploadFile).toHaveBeenCalled();
  });
  {{else}}
  {{#isDownload this}}
  it('{{camelCase name}} sends download request', async () => {
    await resource.{{camelCase name}}({{#each pathParams}}'test-id'{{#unless @last}}, {{/unless}}{{/each}});
    expect(mockClient.downloadFile).toHaveBeenCalled();
  });
  {{else}}
  it('{{camelCase name}} sends correct request', async () => {
    {{#if (eq (lowercase httpMethod) "get")}}
    await resource.{{camelCase name}}({{#each pathParams}}'test-id'{{#unless @last}}, {{/unless}}{{/each}});
    expect(mockClient.get).toHaveBeenCalledWith(
      '{{{path}}}',
      expect.objectContaining({
        pathParams: expect.any(Object),
      })
    );
    {{else if (eq (lowercase httpMethod) "post")}}
    await resource.{{camelCase name}}({{#each pathParams}}'test-id', {{/each}}{{#ifHasBody this}}{}{{/ifHasBody}});
    expect(mockClient.post).toHaveBeenCalled();
    {{else if (eq (lowercase httpMethod) "put")}}
    await resource.{{camelCase name}}({{#each pathParams}}'test-id', {{/each}}{{#ifHasBody this}}{}{{/ifHasBody}});
    expect(mockClient.put).toHaveBeenCalled();
    {{else if (eq (lowercase httpMethod) "patch")}}
    await resource.{{camelCase name}}({{#each pathParams}}'test-id', {{/each}}{{#ifHasBody this}}{}{{/ifHasBody}});
    expect(mockClient.patch).toHaveBeenCalled();
    {{else if (eq (lowercase httpMethod) "delete")}}
    await resource.{{camelCase name}}({{#each pathParams}}'test-id'{{#unless @last}}, {{/unless}}{{/each}});
    expect(mockClient.delete).toHaveBeenCalled();
    {{/if}}
  });
  {{/isDownload}}
  {{/isUpload}}
  {{/unless}}

{{/each}}
});
