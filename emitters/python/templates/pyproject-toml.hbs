[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{langConfig.packageName}}"
version = "{{metadata.version}}"
description = "Python SDK for the Blackboard Learn REST API"
license = "{{metadata.license}}"
requires-python = ">={{langConfig.minVersion}}"
keywords = ["blackboard", "learn", "lms", "sdk", "rest-api", "education"]
classifiers = [
    "Development Status :: 4 - Beta",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: Apache Software License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3.14",
    "Typing :: Typed",
]
dependencies = [
    "httpx>=0.25.0",
    "pydantic>=2.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "pytest-asyncio>=0.21",
    "ruff>=0.4.0",
    "mypy>=1.10",
]

[project.urls]
Homepage = "https://github.com/blackboard/learn-python"
Documentation = "https://github.com/blackboard/learn-python#readme"
Repository = "https://github.com/blackboard/learn-python"

[tool.hatch.build.targets.wheel]
packages = ["src/blackboard_learn"]

[tool.ruff]
target-version = "py312"
line-length = 120

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]

[tool.mypy]
python_version = "3.12"
strict = true
