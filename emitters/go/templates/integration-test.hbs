package lms_test

import (
	"context"
	"os"
	"testing"

	lms "{{goModule}}"
)

func mockServerURL() string {
	if url := os.Getenv("MOCK_SERVER_URL"); url != "" {
		return url
	}
	return "http://127.0.0.1:4010"
}

func setupClient(t *testing.T) *lms.Client {
	t.Helper()
	url := mockServerURL()
	client := lms.NewClient(
		url,
		"test-client-id",
		"test-client-secret",
	)
	// Pre-set a mock token so the OAuth client doesn't try to authenticate against the mock server
	client.SetAccessToken("mock-token")
	return client
}

