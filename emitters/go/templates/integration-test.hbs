func TestIntegration_{{PascalCase ../path}}_{{PascalCase name}}(t *testing.T) {
	if testing.Short() {
		t.Skip("integration test")
	}
	client := setupClient(t)
	ctx := context.Background()

	{{#if (isVoid response.type)}}
	err := client.{{goResourceChain ../path}}.{{PascalCase name}}(ctx{{#each pathParams}}, {{goIntegrationTestValue this}}{{/each}})
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	{{else}}
	result, err := client.{{goResourceChain ../path}}.{{PascalCase name}}(ctx{{#each pathParams}}, {{goIntegrationTestValue this}}{{/each}})
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if result == nil {
		t.Fatal("expected non-nil result")
	}
	{{/if}}
}

