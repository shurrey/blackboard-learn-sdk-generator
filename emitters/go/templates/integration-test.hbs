package learn_test

import (
	"context"
	"errors"
	"os"
	"testing"

	learn "{{goModule}}"
)

func mockServerURL() string {
	if url := os.Getenv("MOCK_SERVER_URL"); url != "" {
		return url
	}
	return "http://127.0.0.1:4010"
}

func setupClient(t *testing.T) *learn.Client {
	t.Helper()
	url := mockServerURL()
	client := learn.NewClient(
		url,
		"test-client-id",
		"test-client-secret",
		learn.WithBaseURL(url+"/learn/api/public"),
	)
	return client
}

{{#each resources}}
{{#each methods}}
{{#if (eq kind "list")}}
func TestIntegration_{{PascalCase ../name}}_{{PascalCase name}}(t *testing.T) {
	client := setupClient(t)
	ctx := context.Background()

	result, err := client.{{PascalCase ../name}}().{{PascalCase name}}(ctx{{#each pathParams}}, "_1_1"{{/each}})
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if result == nil {
		t.Fatal("expected non-nil result")
	}
}

