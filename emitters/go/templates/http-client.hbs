package learn

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"log/slog"
	"math"
	"math/rand"
	"mime/multipart"
	"net/http"
	"net/url"
	"strconv"
	"strings"
	"time"
)

// HTTPClient handles HTTP requests with retry and rate limiting.
type HTTPClient struct {
	baseURL    string
	timeout    time.Duration
	maxRetries int
	authClient *OAuth2Client
	httpClient *http.Client
	logger     *slog.Logger
	logLevel   string
}

var retryStatusCodes = map[int]bool{
	429: true, 500: true, 502: true, 503: true, 504: true,
}

// NewHTTPClient creates a new HTTPClient.
func NewHTTPClient(baseURL string, timeoutMs int, maxRetries int, authClient *OAuth2Client) *HTTPClient {
	return &HTTPClient{
		baseURL:    strings.TrimRight(baseURL, "/"),
		timeout:    time.Duration(timeoutMs) * time.Millisecond,
		maxRetries: maxRetries,
		authClient: authClient,
		httpClient: &http.Client{Timeout: time.Duration(timeoutMs) * time.Millisecond},
		logLevel:   "none",
	}
}

// SetLogger sets the logger and log level on the HTTPClient.
func (c *HTTPClient) SetLogger(logger *slog.Logger, logLevel string) {
	c.logger = logger
	c.logLevel = logLevel
}

func (c *HTTPClient) Get(ctx context.Context, path string, pathParams map[string]string, result interface{}) error {
	return c.request(ctx, "GET", path, pathParams, nil, result)
}

func (c *HTTPClient) Post(ctx context.Context, path string, pathParams map[string]string, body interface{}, result interface{}) error {
	return c.request(ctx, "POST", path, pathParams, body, result)
}

func (c *HTTPClient) Put(ctx context.Context, path string, pathParams map[string]string, body interface{}, result interface{}) error {
	return c.request(ctx, "PUT", path, pathParams, body, result)
}

func (c *HTTPClient) Patch(ctx context.Context, path string, pathParams map[string]string, body interface{}, result interface{}) error {
	return c.request(ctx, "PATCH", path, pathParams, body, result)
}

func (c *HTTPClient) Delete(ctx context.Context, path string, pathParams map[string]string) error {
	return c.request(ctx, "DELETE", path, pathParams, nil, nil)
}

// RawRequest makes a raw HTTP request and returns the response.
func (c *HTTPClient) RawRequest(ctx context.Context, method, rawURL string) (*http.Response, error) {
	req, err := http.NewRequestWithContext(ctx, method, rawURL, nil)
	if err != nil {
		return nil, err
	}
	if c.authClient != nil {
		token, err := c.authClient.GetToken(ctx)
		if err != nil {
			return nil, fmt.Errorf("auth error: %w", err)
		}
		req.Header.Set("Authorization", "Bearer "+token)
	}
	req.Header.Set("Accept", "application/json")

	return c.httpClient.Do(req)
}

// FileDownload represents a downloaded file.
type FileDownload struct {
	Data        []byte
	ContentType string
	Filename    string
}

// UploadFile uploads a file using multipart/form-data.
func (c *HTTPClient) UploadFile(ctx context.Context, path string, pathParams map[string]string,
	fieldName string, filename string, fileData []byte, result interface{}) error {
	reqURL := c.buildURL(path, pathParams)

	token, err := c.authClient.GetToken(ctx)
	if err != nil {
		return fmt.Errorf("auth error: %w", err)
	}

	var buf bytes.Buffer
	writer := multipart.NewWriter(&buf)
	part, err := writer.CreateFormFile(fieldName, filename)
	if err != nil {
		return fmt.Errorf("create form file: %w", err)
	}
	if _, err := part.Write(fileData); err != nil {
		return fmt.Errorf("write file data: %w", err)
	}
	writer.Close()

	req, err := http.NewRequestWithContext(ctx, "POST", reqURL, &buf)
	if err != nil {
		return err
	}
	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", writer.FormDataContentType())

	resp, err := c.httpClient.Do(req)
	if err != nil {
		return fmt.Errorf("upload failed: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode >= 200 && resp.StatusCode < 300 {
		if resp.StatusCode == 204 || result == nil {
			return nil
		}
		return json.NewDecoder(resp.Body).Decode(result)
	}
	respBody, _ := io.ReadAll(resp.Body)
	return NewAPIError(resp.StatusCode, string(respBody), "")
}

// DownloadFile downloads a file as raw bytes.
func (c *HTTPClient) DownloadFile(ctx context.Context, path string, pathParams map[string]string) (*FileDownload, error) {
	reqURL := c.buildURL(path, pathParams)

	token, err := c.authClient.GetToken(ctx)
	if err != nil {
		return nil, fmt.Errorf("auth error: %w", err)
	}

	req, err := http.NewRequestWithContext(ctx, "GET", reqURL, nil)
	if err != nil {
		return nil, err
	}
	req.Header.Set("Authorization", "Bearer "+token)

	resp, err := c.httpClient.Do(req)
	if err != nil {
		return nil, fmt.Errorf("download failed: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode >= 200 && resp.StatusCode < 300 {
		data, err := io.ReadAll(resp.Body)
		if err != nil {
			return nil, fmt.Errorf("read body: %w", err)
		}
		contentType := resp.Header.Get("Content-Type")
		if contentType == "" {
			contentType = "application/octet-stream"
		}
		filename := ""
		if disp := resp.Header.Get("Content-Disposition"); disp != "" {
			if idx := strings.Index(disp, "filename="); idx >= 0 {
				filename = strings.Trim(disp[idx+9:], "\" ")
			}
		}
		return &FileDownload{Data: data, ContentType: contentType, Filename: filename}, nil
	}
	respBody, _ := io.ReadAll(resp.Body)
	return nil, NewAPIError(resp.StatusCode, string(respBody), "")
}

func (c *HTTPClient) request(ctx context.Context, method, path string, pathParams map[string]string, body interface{}, result interface{}) error {
	reqURL := c.buildURL(path, pathParams)

	for attempt := 0; attempt <= c.maxRetries; attempt++ {
		var token string
		if c.authClient != nil {
			var err error
			token, err = c.authClient.GetToken(ctx)
			if err != nil {
				return fmt.Errorf("auth error: %w", err)
			}
		}

		var bodyReader io.Reader
		if body != nil {
			jsonBody, err := json.Marshal(body)
			if err != nil {
				return fmt.Errorf("marshal error: %w", err)
			}
			bodyReader = bytes.NewReader(jsonBody)
		}

		req, err := http.NewRequestWithContext(ctx, method, reqURL, bodyReader)
		if err != nil {
			return err
		}
		if token != "" {
			req.Header.Set("Authorization", "Bearer "+token)
		}
		req.Header.Set("Content-Type", "application/json")
		req.Header.Set("Accept", "application/json")

		resp, err := c.httpClient.Do(req)
		if err != nil {
			if attempt == c.maxRetries {
				return fmt.Errorf("request failed: %w", err)
			}
			time.Sleep(c.retryDelay(nil, attempt))
			continue
		}
		defer resp.Body.Close()

		if c.logLevel != "none" && c.logger != nil {
			c.logger.Info("[BlackboardSDK] request", "method", method, "url", reqURL, "status", resp.StatusCode)
			if c.logLevel == "verbose" {
				respHeaders := make(map[string]string)
				for k, v := range resp.Header {
					respHeaders[k] = strings.Join(v, ", ")
				}
				c.logger.Debug("[BlackboardSDK] response details", "headers", respHeaders)
			}
		}

		if resp.StatusCode >= 200 && resp.StatusCode < 300 {
			if resp.StatusCode == 204 || result == nil {
				return nil
			}
			return json.NewDecoder(resp.Body).Decode(result)
		}

		if !retryStatusCodes[resp.StatusCode] || attempt == c.maxRetries {
			respBody, _ := io.ReadAll(resp.Body)
			return NewAPIError(resp.StatusCode, string(respBody), resp.Header.Get("Retry-After"))
		}

		resp.Body.Close()
		time.Sleep(c.retryDelay(resp, attempt))
	}

	return fmt.Errorf("unreachable")
}

func (c *HTTPClient) buildURL(path string, pathParams map[string]string) string {
	u := path
	for key, value := range pathParams {
		u = strings.ReplaceAll(u, "{"+key+"}", url.PathEscape(value))
	}
	if !strings.HasPrefix(u, "http") {
		u = c.baseURL + u
	}
	return u
}

func (c *HTTPClient) retryDelay(resp *http.Response, attempt int) time.Duration {
	if resp != nil {
		if ra := resp.Header.Get("Retry-After"); ra != "" {
			if seconds, err := strconv.Atoi(ra); err == nil {
				return time.Duration(seconds) * time.Second
			}
		}
	}
	delay := float64(500) * math.Pow(2, float64(attempt))
	jitter := rand.Float64() * 100
	ms := math.Min(delay+jitter, 30000)
	return time.Duration(ms) * time.Millisecond
}

// BaseURL returns the base URL.
func (c *HTTPClient) BaseURL() string {
	return c.baseURL
}
