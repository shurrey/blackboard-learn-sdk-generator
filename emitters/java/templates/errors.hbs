public class APIError extends RuntimeException {

    private final int status;
    private final String responseBody;

    public APIError(String message, int status, String responseBody) {
        super(message);
        this.status = status;
        this.responseBody = responseBody;
    }

    public int getStatus() { return status; }
    public String getResponseBody() { return responseBody; }

    public static APIError fromResponse(int statusCode, String body) {
        return fromResponse(statusCode, body, null);
    }

    public static APIError fromResponse(int statusCode, String body, String retryAfter) {
        String message;
        try {
            var mapper = new ObjectMapper();
            var tree = mapper.readTree(body);
            message = tree.has("message") ? tree.get("message").asText() : body;
        } catch (Exception e) {
            message = body;
        }

        return switch (statusCode) {
            case 400 -> new BadRequestError(message, statusCode, body);
            case 401 -> new AuthenticationError(message, statusCode, body);
            case 403 -> new PermissionError(message, statusCode, body);
            case 404 -> new NotFoundError(message, statusCode, body);
            case 409 -> new ConflictError(message, statusCode, body);
            case 429 -> new RateLimitError(message, statusCode, body, retryAfter);
            default -> new APIError(message, statusCode, body);
        };
    }
}

