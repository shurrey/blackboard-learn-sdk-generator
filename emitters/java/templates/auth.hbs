    /** Get a valid access token, refreshing via client_credentials if needed. */
    public synchronized String getToken() {
        if (accessToken != null && System.currentTimeMillis() < tokenExpiry - 60_000) {
            return accessToken;
        }
        return fetchToken();
    }

    // ── Three-legged OAuth (authorization_code + PKCE) ──────────────────────

    /**
     * Result of generating a PKCE authorization URL.
     */
    public static class AuthorizationResult {
        private final String url;
        private final String codeVerifier;

        public AuthorizationResult(String url, String codeVerifier) {
            this.url = url;
            this.codeVerifier = codeVerifier;
        }

        /** The authorization URL to redirect the user to. */
        public String getUrl() { return url; }

        /** The PKCE code verifier — store this and pass it to {@link #exchangeCode}. */
        public String getCodeVerifier() { return codeVerifier; }
