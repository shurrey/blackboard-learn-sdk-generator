    /**
     * Generate a PKCE authorization URL for the three-legged OAuth flow.
     *
     * @param redirectUri The URI to redirect the user back to after authorization.
     * @param scope       Optional OAuth scope (may be null).
     * @param state       Optional state parameter for CSRF protection (may be null).
     * @return An {@link AuthorizationResult} containing the URL and code verifier.
     */
    public AuthorizationResult getAuthorizationUrl(String redirectUri, String scope, String state) {
        String codeVerifier = generateCodeVerifier();
        String codeChallenge = generateCodeChallenge(codeVerifier);

        StringBuilder url = new StringBuilder();
        url.append(baseUrl).append("{{auth.threeLegged.authorizeEndpoint}}");
        url.append("?response_type=code");
        url.append("&client_id=").append(urlEncode(clientId));
        url.append("&redirect_uri=").append(urlEncode(redirectUri));
        url.append("&code_challenge=").append(urlEncode(codeChallenge));
        url.append("&code_challenge_method=S256");

        if (scope != null && !scope.isEmpty()) {
            url.append("&scope=").append(urlEncode(scope));
        }
        if (state != null && !state.isEmpty()) {
            url.append("&state=").append(urlEncode(state));
        }

        return new AuthorizationResult(url.toString(), codeVerifier);
