<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>{{langConfig.minVersion}}</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>{{langConfig.packageName}}</PackageId>
    <Version>{{metadata.version}}</Version>
    <Authors>Blackboard</Authors>
    <Description>C# SDK for the Blackboard Learn REST API</Description>
    <PackageLicenseExpression>{{metadata.license}}</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/blackboard/learn-csharp</RepositoryUrl>
    <PackageTags>blackboard;learn;lms;sdk;education</PackageTags>
  </PropertyGroup>

</Project>
