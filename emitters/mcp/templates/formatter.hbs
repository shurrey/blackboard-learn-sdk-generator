"""
Agent-friendly formatters for Blackboard Learn API responses.

All formatters convert raw API JSON responses into well-structured,
human-readable text. The output is optimized for AI agents:
  - Markdown formatting for structure
  - Key information surfaced first
  - Pagination hints when more data is available
  - No raw JSON or internal IDs unless actionable

Generated by blackboard-learn-sdk-generator v{{metadata.generatorVersion}}
"""

from __future__ import annotations

from typing import Any


def _safe_get(data: dict, *keys: str, default: str = "N/A") -> str:
    """Safely get a nested value from a dictionary."""
    current = data
    for key in keys:
        if isinstance(current, dict):
            current = current.get(key, default)
        else:
            return default
    return str(current) if current is not None else default


def _format_availability(data: dict) -> str:
    """Format availability status to a readable string."""
    avail = data.get("availability", {})
    available = avail.get("available", "Unknown")
    mapping = {"Yes": "Available", "No": "Unavailable", "Term": "Term-dependent"}
    return mapping.get(available, available)


def _pagination_hint(data: dict) -> str:
    """Generate a pagination hint if more results are available."""
    paging = data.get("paging", {})
    next_page = paging.get("nextPage")
    if next_page:
        return (
            "\n---\n"
            "**More results available.** Use `learn_execute_api` with the "
            f"path from the next page link to fetch additional results."
        )
    return ""


# ─── Course Formatters ───────────────────────────────────────────────────────


def format_course_list(data: dict) -> str:
    """Format a list of courses for display.

    Args:
        data: Raw API response from GET /v3/courses.

    Returns:
        Markdown-formatted course list with count and pagination hints.
    """
    results = data.get("results", [])
    if not results:
        return "## No Courses Found\nNo courses matched your search criteria."

    lines = [f"## Courses Found: {len(results)}"]
    lines.append("")

    for course in results:
        name = course.get("name", "Untitled")
        course_id_val = course.get("courseId", "N/A")
        bb_id = course.get("id", "N/A")
        term = _safe_get(course, "term", "name")
        created = course.get("created", "N/A")
        availability = _format_availability(course)

        lines.append(f"- **{name}** (ID: `{bb_id}`)")
        lines.append(f"  Course ID: `{course_id_val}` | Availability: {availability}")
        if term != "N/A":
            lines.append(f"  Term: {term}")
        lines.append("")

    lines.append(_pagination_hint(data))
    return "\n".join(lines)


def format_course_detail(data: dict) -> str:
    """Format detailed course information.

    Args:
        data: Raw API response from GET /v3/courses/{courseId}.

    Returns:
        Markdown-formatted course details.
    """
    lines = [f"## Course: {data.get('name', 'Untitled')}"]
    lines.append("")
    lines.append(f"- **Course ID**: `{data.get('courseId', 'N/A')}`")
    lines.append(f"- **ID**: `{data.get('id', 'N/A')}`")

    desc = data.get("description", "")
    if desc:
        # Strip HTML tags for readability
        import re
        clean_desc = re.sub(r"<[^>]+>", "", desc).strip()
        if clean_desc:
            lines.append(f"- **Description**: {clean_desc[:500]}")

    lines.append(f"- **Availability**: {_format_availability(data)}")
    lines.append(f"- **Created**: {data.get('created', 'N/A')}")
    lines.append(f"- **Modified**: {data.get('modified', 'N/A')}")

    term = data.get("term", {})
    if term:
        lines.append(f"- **Term**: {term.get('name', 'N/A')} (ID: `{term.get('id', 'N/A')}`)")

    enrollment = data.get("enrollment", {})
    if enrollment:
        lines.append(f"- **Enrollment Type**: {enrollment.get('type', 'N/A')}")

    locale = data.get("locale", {})
    if locale:
        lines.append(f"- **Locale**: {locale.get('id', 'N/A')}")

    ultra_status = data.get("ultraStatus", "")
    if ultra_status:
        lines.append(f"- **Ultra Status**: {ultra_status}")

    return "\n".join(lines)


def format_calendar_items(data: dict) -> str:
    """Format calendar items for display.

    Args:
        data: Raw API response from GET /v1/calendars/items.

    Returns:
        Markdown-formatted calendar with date grouping.
    """
    results = data.get("results", [])
    if not results:
        return "## No Calendar Items\nNo calendar items found for the specified criteria."

    lines = [f"## Calendar Items: {len(results)}"]
    lines.append("")

    for item in results:
        title = item.get("title", "Untitled")
        item_type = item.get("type", "Unknown")
        start = item.get("start", "N/A")
        end = item.get("end", "")
        course_name = _safe_get(item, "calendarName")

        lines.append(f"- **{title}** ({item_type})")
        lines.append(f"  Date: {start}")
        if end:
            lines.append(f"  End: {end}")
        if course_name != "N/A":
            lines.append(f"  Course: {course_name}")
        lines.append("")

    lines.append(_pagination_hint(data))
    return "\n".join(lines)


# ─── User Formatters ─────────────────────────────────────────────────────────


def format_user_info(data: dict) -> str:
    """Format user information for display.

    Args:
        data: Raw API response from GET /v1/users/{userId}.

    Returns:
        Markdown-formatted user profile.
    """
    name_data = data.get("name", {})
    display_name = (
        f"{name_data.get('given', '')} {name_data.get('family', '')}".strip()
        or data.get("userName", "Unknown User")
    )

    lines = [f"## User: {display_name}"]
    lines.append("")
    lines.append(f"- **Username**: `{data.get('userName', 'N/A')}`")
    lines.append(f"- **ID**: `{data.get('id', 'N/A')}`")

    contact = data.get("contact", {})
    email = contact.get("email", data.get("emailAddress", "N/A"))
    lines.append(f"- **Email**: {email}")

    student_id = data.get("studentId", "")
    if student_id:
        lines.append(f"- **Student ID**: `{student_id}`")

    external_id = data.get("externalId", "")
    if external_id:
        lines.append(f"- **External ID**: `{external_id}`")

    roles = data.get("systemRoleIds", [])
    if roles:
        lines.append(f"- **System Roles**: {', '.join(roles)}")

    lines.append(f"- **Availability**: {_format_availability(data)}")
    lines.append(f"- **Created**: {data.get('created', 'N/A')}")

    last_login = data.get("lastLogin", "")
    if last_login:
        lines.append(f"- **Last Login**: {last_login}")

    return "\n".join(lines)


# ─── Content Formatters ──────────────────────────────────────────────────────


def format_content_item(data: dict, action: str = "retrieved") -> str:
    """Format a single content item for display.

    Args:
        data: Raw API response from content create/update.
        action: The action performed (e.g., "created", "updated").

    Returns:
        Markdown-formatted content item summary.
    """
    lines = [f"## Content {action.capitalize()}"]
    lines.append("")
    lines.append(f"- **Title**: {data.get('title', 'Untitled')}")
    lines.append(f"- **ID**: `{data.get('id', 'N/A')}`")

    handler = data.get("contentHandler", {})
    content_type = handler.get("id", "unknown").replace("resource/", "")
    lines.append(f"- **Type**: {content_type}")

    parent_id = data.get("parentId", "root")
    lines.append(f"- **Parent**: `{parent_id}`")

    position = data.get("position", "")
    if position:
        lines.append(f"- **Position**: {position}")

    lines.append(f"- **Availability**: {_format_availability(data)}")
    lines.append(f"- **Created**: {data.get('created', 'N/A')}")

    return "\n".join(lines)


def format_content_tree(data: dict, course_id: str) -> str:
    """Format a course content tree for display.

    Args:
        data: Raw API response from GET /v1/courses/{courseId}/contents.
        course_id: The course identifier for the header.

    Returns:
        Markdown-formatted hierarchical content tree.
    """
    results = data.get("results", [])
    if not results:
        return f"## Content Tree for `{course_id}`\nThis course has no content items."

    lines = [f"## Content Tree for `{course_id}`: {len(results)} items"]
    lines.append("")

    for item in results:
        _format_content_tree_item(item, lines, indent=0)

    lines.append(_pagination_hint(data))
    return "\n".join(lines)


def _format_content_tree_item(item: dict, lines: list[str], indent: int) -> None:
    """Recursively format a content tree item."""
    prefix = "  " * indent
    handler = item.get("contentHandler", {})
    content_type = handler.get("id", "unknown").replace("resource/", "")

    icon = "+" if content_type == "folder" else "-"
    title = item.get("title", "Untitled")
    item_id = item.get("id", "N/A")

    lines.append(f"{prefix}{icon} **{title}** (ID: `{item_id}`, type: {content_type})")

    # Recursively format children if present
    children = item.get("children", [])
    for child in children:
        _format_content_tree_item(child, lines, indent + 1)


# ─── Grade Formatters ────────────────────────────────────────────────────────


def format_student_grades(data: dict, course_id: str, user_id: str) -> str:
    """Format all grades for a student in a course.

    Args:
        data: Raw API response from GET /v2/courses/{courseId}/gradebook/users/{userId}.
        course_id: The course identifier for the header.
        user_id: The user identifier for the header.

    Returns:
        Markdown-formatted grade report with table.
    """
    results = data.get("results", [])
    if not results:
        return (
            f"## Grades for `{user_id}` in `{course_id}`\n"
            f"No grades found for this student in this course."
        )

    lines = [f"## Grades for `{user_id}` in `{course_id}`: {len(results)} columns"]
    lines.append("")
    lines.append("| Column | Score | Grade | Status | Updated |")
    lines.append("|--------|-------|-------|--------|---------|")

    for grade in results:
        column_id = grade.get("columnId", "N/A")
        score = grade.get("score", "")
        text = grade.get("text", "")
        status = grade.get("status", "N/A")
        updated = grade.get("modified", "N/A")

        score_display = str(score) if score != "" else "-"
        grade_display = text if text else "-"

        lines.append(
            f"| `{column_id}` | {score_display} | {grade_display} | {status} | {updated} |"
        )

    lines.append("")
    lines.append(_pagination_hint(data))
    return "\n".join(lines)


def format_grade_submission(
    data: dict, course_id: str, column_id: str, user_id: str
) -> str:
    """Format a grade submission confirmation.

    Args:
        data: Raw API response from PATCH grade endpoint.
        course_id: The course identifier.
        column_id: The gradebook column identifier.
        user_id: The student identifier.

    Returns:
        Markdown-formatted grade submission confirmation.
    """
    lines = ["## Grade Submitted"]
    lines.append("")
    lines.append(f"- **Course**: `{course_id}`")
    lines.append(f"- **Column**: `{column_id}`")
    lines.append(f"- **Student**: `{user_id}`")

    score = data.get("score", "N/A")
    lines.append(f"- **Score**: {score}")

    text = data.get("text", "")
    if text:
        lines.append(f"- **Grade**: {text}")

    notes = data.get("notes", "")
    if notes:
        lines.append(f"- **Notes**: {notes}")

    lines.append(f"- **Status**: {data.get('status', 'N/A')}")
    lines.append(f"- **Updated**: {data.get('modified', 'N/A')}")

    return "\n".join(lines)


# ─── Enrollment Formatters ───────────────────────────────────────────────────


def format_enrollment_list(data: dict, course_id: str) -> str:
    """Format a list of course enrollments.

    Args:
        data: Raw API response from GET /v1/courses/{courseId}/users.
        course_id: The course identifier for the header.

    Returns:
        Markdown-formatted enrollment roster with table.
    """
    results = data.get("results", [])
    if not results:
        return f"## Enrollments for `{course_id}`\nNo enrollments found."

    lines = [f"## Enrollments for `{course_id}`: {len(results)} users"]
    lines.append("")
    lines.append("| Name | User ID | Role | Availability | Created |")
    lines.append("|------|---------|------|--------------|---------|")

    for enrollment in results:
        user = enrollment.get("user", {})
        user_name_data = user.get("name", {})
        name = (
            f"{user_name_data.get('given', '')} {user_name_data.get('family', '')}".strip()
            or user.get("userName", "Unknown")
        )
        user_id = enrollment.get("userId", user.get("id", "N/A"))
        role = enrollment.get("courseRoleId", "N/A")
        avail = _format_availability(enrollment)
        created = enrollment.get("created", "N/A")

        lines.append(f"| {name} | `{user_id}` | {role} | {avail} | {created} |")

    lines.append("")
    lines.append(_pagination_hint(data))
    return "\n".join(lines)


def format_enrollment_action(
    data: dict | None, action: str, course_id: str, user_id: str
) -> str:
    """Format an enrollment action confirmation.

    Args:
        data: Raw API response (None for unenroll/delete).
        action: The action performed (e.g., "enrolled", "unenrolled").
        course_id: The course identifier.
        user_id: The user identifier.

    Returns:
        Markdown-formatted enrollment action confirmation.
    """
    lines = [f"## Enrollment {action.capitalize()}"]
    lines.append("")
    lines.append(f"- **Course**: `{course_id}`")
    lines.append(f"- **User**: `{user_id}`")

    if data:
        role = data.get("courseRoleId", "N/A")
        lines.append(f"- **Role**: {role}")
        lines.append(f"- **Availability**: {_format_availability(data)}")
        lines.append(f"- **Created**: {data.get('created', 'N/A')}")
    else:
        lines.append(f"- **Status**: Successfully {action}")

    return "\n".join(lines)


# ─── Announcement Formatters ─────────────────────────────────────────────────


def format_announcement(data: dict, action: str) -> str:
    """Format an announcement action result.

    Args:
        data: Raw API response from announcement create/update.
        action: The action performed (e.g., "create", "update").

    Returns:
        Markdown-formatted announcement summary.
    """
    action_past = {"create": "Created", "update": "Updated"}.get(action, action)

    lines = [f"## Announcement {action_past}"]
    lines.append("")
    lines.append(f"- **Title**: {data.get('title', 'N/A')}")
    lines.append(f"- **ID**: `{data.get('id', 'N/A')}`")

    # Strip HTML from body for preview
    body = data.get("body", "")
    if body:
        import re
        clean_body = re.sub(r"<[^>]+>", "", body).strip()
        preview = clean_body[:200] + ("..." if len(clean_body) > 200 else "")
        lines.append(f"- **Preview**: {preview}")

    lines.append(f"- **Availability**: {_format_availability(data)}")
    lines.append(f"- **Created**: {data.get('created', 'N/A')}")
    lines.append(f"- **Modified**: {data.get('modified', 'N/A')}")

    return "\n".join(lines)
