"""
Blackboard Learn MCP tools: dynamic API execution.

Provides the learn_execute_api escape-hatch tool that allows agents to call
any Blackboard Learn REST API endpoint directly when no dedicated tool exists.
"""

from __future__ import annotations

import json
import logging
from typing import Literal

from fastmcp import FastMCP

from blackboard_learn_mcp.utils.error_handler import handle_api_error

logger = logging.getLogger(__name__)


def register_dynamic_tools(mcp: FastMCP, get_client):
    """Register the dynamic API execution tool with the MCP server."""

    @mcp.tool()
    async def learn_execute_api(
        method: Literal["GET", "POST", "PUT", "PATCH", "DELETE"],
        path: str,
        query_params: dict | None = None,
        body: dict | None = None,
    ) -> str:
        """Execute any Blackboard Learn REST API endpoint directly.

        This is an escape hatch for operations not covered by the other tools.
        Use this when you need to call a specific API endpoint that doesn't
        have a dedicated tool, or when you need fine-grained control over the
        request.

        IMPORTANT: Prefer the dedicated tools when possible -- they provide
        better formatting and error handling. Only use this tool when no
        dedicated tool exists for your use case.

        The full API reference is at:
        https://developer.blackboard.com/portal/docs/apis/rest/

        Args:
            method: HTTP method for the request (GET, POST, PUT, PATCH, DELETE).
            path: The API path relative to the base URL. Must start with /v1/,
                /v2/, or /v3/. Examples: "/v1/courses/{courseId}/groups",
                "/v1/system/version". Path parameters should already be
                substituted with actual IDs.
            query_params: Optional dictionary of query parameters appended as
                ?key=value pairs. Example: {"limit": 10, "offset": 0}.
            body: Optional JSON request body for POST, PUT, PATCH requests.
                Pass as a dictionary that will be serialized to JSON.

        Returns:
            Formatted text showing the HTTP status code and response body.
        """
        try:
            client = get_client()

            # Validate the path starts with a versioned prefix
            if not path.startswith("/"):
                path = f"/{path}"

            valid_prefixes = ("/v1/", "/v2/", "/v3/")
            if not any(path.startswith(p) for p in valid_prefixes):
                return (
                    f"Error: Invalid path '{path}'. "
                    f"Path must start with /v1/, /v2/, or /v3/. "
                    f"Example: /v1/system/version"
                )

            # Build request kwargs
            kwargs = {}
            if query_params:
                kwargs["params"] = query_params
            if body and method in ("POST", "PUT", "PATCH"):
                kwargs["json"] = body

            # Execute the request
            response = client.request(method, path, **kwargs)
            status_code = response.status_code

            # Try to parse JSON response
            try:
                data = response.json()
                formatted_body = json.dumps(data, indent=2, default=str)
            except (json.JSONDecodeError, ValueError):
                formatted_body = response.text or "(empty response)"

            # Build the formatted output
            status_emoji = "Success" if 200 <= status_code < 300 else "Error"
            lines = [
                f"## API Response ({status_code} {status_emoji})",
                f"**Method**: {method}",
                f"**Path**: {path}",
            ]

            if query_params:
                lines.append(f"**Query**: {json.dumps(query_params)}")

            lines.append("")
            lines.append("### Response Body")
            lines.append(f"```json\n{formatted_body}\n```")

            # Add pagination hint if present
            if isinstance(data, dict) and "paging" in data:
                paging = data["paging"]
                if paging.get("nextPage"):
                    lines.append("")
                    lines.append(
                        f"**Note**: More results available. "
                        f"Next page: `{paging['nextPage']}`"
                    )

            return "\n".join(lines)

        except Exception as e:
            return handle_api_error(e, "learn_execute_api")
