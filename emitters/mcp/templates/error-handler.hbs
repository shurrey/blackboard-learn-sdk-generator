"""
Error handler for Blackboard LMS MCP tools.

Converts exceptions into helpful, actionable error messages that
guide agents toward resolving the issue. Errors are returned as
formatted strings (never raised) because MCP tools must always
return a string response.

Generated by blackboard-lms-sdk-generator v{{metadata.generatorVersion}}
"""

from __future__ import annotations

import json
import logging

logger = logging.getLogger(__name__)


def handle_api_error(error: Exception, tool_name: str) -> str:
    """Convert an exception into a helpful error message for agents.

    This function never raises -- it always returns a formatted string
    describing the error and suggesting next steps. This is critical
    for MCP tools because the agent needs to understand what went wrong
    and decide how to recover.

    Args:
        error: The exception that occurred.
        tool_name: The name of the tool that failed (for context).

    Returns:
        A formatted error string with details and recovery suggestions.
    """
    logger.error("Tool %s failed: %s", tool_name, error, exc_info=True)

    error_type = type(error).__name__

    # Handle httpx HTTP errors (most common)
    try:
        import httpx

        if isinstance(error, httpx.HTTPStatusError):
            return _format_http_error(error, tool_name)
        if isinstance(error, httpx.ConnectError):
            return _format_connection_error(error, tool_name)
        if isinstance(error, httpx.TimeoutException):
            return _format_timeout_error(error, tool_name)
    except ImportError:
        pass

    # Handle authentication/configuration errors
    if isinstance(error, ValueError) and "environment variable" in str(error).lower():
        return _format_config_error(error, tool_name)

    # Handle JSON decode errors
    if isinstance(error, (json.JSONDecodeError,)):
        return (
            f"## Error in {tool_name}\n\n"
            f"**Type**: Invalid Response\n"
            f"**Details**: The API returned a response that could not be parsed as JSON.\n\n"
            f"### Suggestions\n"
            f"- The API endpoint may be returning HTML (check if the base URL is correct)\n"
            f"- The server may be experiencing issues\n"
            f"- Try the request again with `learn_execute_api` for raw response details"
        )

    # Generic fallback
    return (
        f"## Error in {tool_name}\n\n"
        f"**Type**: {error_type}\n"
        f"**Details**: {str(error)}\n\n"
        f"### Suggestions\n"
        f"- Check that the input parameters are correct\n"
        f"- Verify the Blackboard LMS instance is accessible\n"
        f"- Try using `learn_execute_api` for more control over the request"
    )


def _format_http_error(error, tool_name: str) -> str:
    """Format an HTTP status error with actionable guidance."""
    import httpx

    assert isinstance(error, httpx.HTTPStatusError)

    status = error.response.status_code
    method = error.request.method
    url = str(error.request.url)

    # Try to extract the error message from the response body
    detail = ""
    try:
        body = error.response.json()
        detail = body.get("message", body.get("error", ""))
        if isinstance(detail, dict):
            detail = json.dumps(detail)
    except Exception:
        detail = error.response.text[:500] if error.response.text else ""

    lines = [
        f"## Error in {tool_name}",
        "",
        f"**HTTP {status}** on {method} `{url}`",
    ]

    if detail:
        lines.append(f"**Message**: {detail}")

    lines.append("")
    lines.append("### What This Means")

    # Status-specific guidance
    if status == 400:
        lines.append("The request was malformed or contained invalid parameters.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Check that all required parameters are provided and valid")
        lines.append("- Verify ID formats (primary ID, externalId:{id}, userName:{name})")
        lines.append("- Ensure enum values match the expected options exactly")
    elif status == 401:
        lines.append("Authentication failed -- the token may be expired or invalid.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Check that BLACKBOARD_CLIENT_ID and BLACKBOARD_CLIENT_SECRET are correct")
        lines.append("- Verify the application is registered and active in Blackboard")
        lines.append("- The token may have expired; restart the MCP server to re-authenticate")
    elif status == 403:
        lines.append("The authenticated user/application does not have permission for this operation.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Verify the API application has the required entitlements")
        lines.append("- Check if the operation requires a specific system role")
        lines.append("- Some operations require course-level permissions (e.g., instructor role)")
        lines.append("- Contact the Blackboard administrator to review application permissions")
    elif status == 404:
        lines.append("The requested resource was not found.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Verify the ID is correct (use `learn_search_courses` or `learn_get_user_info` to find IDs)")
        lines.append("- Check the ID format -- Blackboard IDs look like `_123_1`")
        lines.append("- For alternative lookups, use prefixed formats: `userName:{name}`, `externalId:{id}`, `courseId:{id}`")
        lines.append("- The resource may have been deleted or may not be accessible")
    elif status == 409:
        lines.append("The request conflicts with the current state of the resource.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- The resource may already exist (e.g., duplicate enrollment)")
        lines.append("- Try fetching the current state first before modifying")
    elif status == 429:
        lines.append("Too many requests -- the API rate limit has been exceeded.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Wait a moment before retrying")
        lines.append("- Reduce the frequency of API calls")
        lines.append("- Consider using smaller page sizes (lower limit values)")
    elif status >= 500:
        lines.append("The Blackboard LMS server encountered an internal error.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- This is a server-side issue; try again in a few moments")
        lines.append("- If the error persists, the Blackboard instance may be under maintenance")
        lines.append("- Check the Blackboard system status page if available")
    else:
        lines.append(f"An unexpected HTTP {status} error occurred.")
        lines.append("")
        lines.append("### Suggestions")
        lines.append("- Review the error details above")
        lines.append("- Try the request with `learn_execute_api` for more control")

    return "\n".join(lines)


def _format_connection_error(error, tool_name: str) -> str:
    """Format a connection error with guidance."""
    return (
        f"## Error in {tool_name}\n\n"
        f"**Type**: Connection Error\n"
        f"**Details**: Could not connect to the Blackboard LMS server.\n\n"
        f"### Suggestions\n"
        f"- Verify BLACKBOARD_BASE_URL is correct and the server is reachable\n"
        f"- Check that the URL includes the protocol (https://)\n"
        f"- The server may be down or behind a firewall\n"
        f"- Check your network connection"
    )


def _format_timeout_error(error, tool_name: str) -> str:
    """Format a timeout error with guidance."""
    return (
        f"## Error in {tool_name}\n\n"
        f"**Type**: Timeout\n"
        f"**Details**: The request to Blackboard LMS timed out.\n\n"
        f"### Suggestions\n"
        f"- The server may be slow or overloaded; try again\n"
        f"- If listing large datasets, try reducing the `limit` parameter\n"
        f"- Check if the Blackboard instance is responsive"
    )


def _format_config_error(error, tool_name: str) -> str:
    """Format a configuration/environment variable error."""
    return (
        f"## Configuration Error in {tool_name}\n\n"
        f"**Details**: {str(error)}\n\n"
        f"### Required Environment Variables\n"
        f"- `BLACKBOARD_BASE_URL`: Your Blackboard LMS instance URL\n"
        f"  Example: `https://your-institution.blackboard.com`\n"
        f"- `BLACKBOARD_CLIENT_ID`: OAuth 2.0 application key\n"
        f"- `BLACKBOARD_CLIENT_SECRET`: OAuth 2.0 application secret\n\n"
        f"### Setup Steps\n"
        f"1. Register an application at https://developer.blackboard.com\n"
        f"2. Set the environment variables in your MCP client configuration\n"
        f"3. Restart the MCP server"
    )
