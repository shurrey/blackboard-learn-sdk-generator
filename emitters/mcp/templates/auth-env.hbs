"""
Environment variable-based authentication for Blackboard Learn.

Reads connection details from environment variables and creates an
authenticated HTTP client using OAuth 2.0 client_credentials flow.

Required environment variables:
    BLACKBOARD_BASE_URL: The base URL of your Blackboard Learn instance
        (e.g., "https://your-institution.blackboard.com")
    BLACKBOARD_CLIENT_ID: The OAuth 2.0 application key (client ID)
    BLACKBOARD_CLIENT_SECRET: The OAuth 2.0 application secret

Optional environment variables:
    BLACKBOARD_API_TOKEN: Pre-obtained bearer token (skips OAuth flow)
"""

from __future__ import annotations

import os
import time
import logging
from typing import Any

import httpx

logger = logging.getLogger(__name__)

# Token endpoint path (relative to base URL)
TOKEN_ENDPOINT = "{{auth.twoLegged.tokenEndpoint}}"


class BlackboardAuthClient:
    """An HTTP client that handles Blackboard Learn OAuth 2.0 authentication.

    Automatically obtains and refreshes bearer tokens using the
    client_credentials grant type. All API requests include the
    Authorization header.
    """

    def __init__(
        self,
        base_url: str,
        client_id: str,
        client_secret: str,
        token: str | None = None,
    ):
        self.base_url = base_url.rstrip("/")
        self.client_id = client_id
        self.client_secret = client_secret
        self._token = token
        self._token_expires_at: float = 0
        self._http = httpx.Client(
            base_url=f"{self.base_url}/learn/api/public",
            timeout=30.0,
            headers={"Accept": "application/json"},
        )

    def _ensure_token(self) -> None:
        """Obtain or refresh the bearer token if needed."""
        if self._token and time.time() < self._token_expires_at - 60:
            return

        logger.debug("Obtaining new bearer token via client_credentials")
        response = httpx.post(
            f"{self.base_url}{TOKEN_ENDPOINT}",
            data={
                "grant_type": "{{auth.twoLegged.grantType}}",
                "client_id": self.client_id,
                "client_secret": self.client_secret,
            },
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
        response.raise_for_status()
        token_data = response.json()

        self._token = token_data["access_token"]
        expires_in = token_data.get("expires_in", 3600)
        self._token_expires_at = time.time() + expires_in
        logger.debug("Token obtained, expires in %d seconds", expires_in)

    def _auth_headers(self) -> dict[str, str]:
        """Get headers with current bearer token."""
        self._ensure_token()
        return {"Authorization": f"Bearer {self._token}"}

    def get(self, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated GET request."""
        return self._http.get(path, headers=self._auth_headers(), **kwargs)

    def post(self, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated POST request."""
        return self._http.post(path, headers=self._auth_headers(), **kwargs)

    def put(self, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated PUT request."""
        return self._http.put(path, headers=self._auth_headers(), **kwargs)

    def patch(self, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated PATCH request."""
        return self._http.patch(path, headers=self._auth_headers(), **kwargs)

    def delete(self, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated DELETE request."""
        return self._http.delete(path, headers=self._auth_headers(), **kwargs)

    def request(self, method: str, path: str, **kwargs: Any) -> httpx.Response:
        """Make an authenticated request with any HTTP method."""
        return self._http.request(
            method, path, headers=self._auth_headers(), **kwargs
        )

    def close(self) -> None:
        """Close the underlying HTTP client."""
        self._http.close()


def get_auth_client() -> BlackboardAuthClient:
    """Create an authenticated client from environment variables.

    Returns:
        A configured BlackboardAuthClient instance.

    Raises:
        ValueError: If required environment variables are not set.
    """
    base_url = os.environ.get("BLACKBOARD_BASE_URL")
    if not base_url:
        raise ValueError(
            "BLACKBOARD_BASE_URL environment variable is required. "
            "Set it to your Blackboard Learn instance URL "
            '(e.g., "https://your-institution.blackboard.com").'
        )

    # Allow pre-obtained token for testing or external token management
    token = os.environ.get("BLACKBOARD_API_TOKEN")
    if token:
        logger.info("Using pre-obtained API token from BLACKBOARD_API_TOKEN")
        return BlackboardAuthClient(
            base_url=base_url,
            client_id="",
            client_secret="",
            token=token,
        )

    client_id = os.environ.get("BLACKBOARD_CLIENT_ID")
    client_secret = os.environ.get("BLACKBOARD_CLIENT_SECRET")

    if not client_id or not client_secret:
        raise ValueError(
            "BLACKBOARD_CLIENT_ID and BLACKBOARD_CLIENT_SECRET environment "
            "variables are required for OAuth authentication. Register an "
            "application at https://developer.blackboard.com to obtain "
            "credentials, or set BLACKBOARD_API_TOKEN with a pre-obtained token."
        )

    return BlackboardAuthClient(
        base_url=base_url,
        client_id=client_id,
        client_secret=client_secret,
    )
