# frozen_string_literal: true

require "faraday"
require "json"
require "logger"

module {{moduleName}}
  # HTTP client with retry, rate limiting, and error handling.
  class HttpClient
    RETRY_STATUS_CODES = [429, 500, 502, 503, 504].freeze
    INITIAL_RETRY_DELAY = 0.5
    MAX_RETRY_DELAY = 30

    attr_reader :base_url

    def initialize(base_url:, timeout:, max_retries:, auth_client:, logger: nil, log_level: "none")
      @base_url = base_url.chomp("/")
      @max_retries = max_retries
      @auth_client = auth_client
      @logger = logger || Logger.new($stdout, progname: "BlackboardSDK")
      @log_level = log_level
      @conn = Faraday.new(url: @base_url) do |f|
        f.options.timeout = timeout
        f.request :json
        f.response :json, content_type: /\bjson$/
      end
    end

    def get(path, path_params: {}, query_params: {})
      request(:get, path, path_params: path_params, query_params: query_params)
    end

    def post(path, path_params: {}, body: nil)
      request(:post, path, path_params: path_params, body: body)
    end

    def put(path, path_params: {}, body: nil)
      request(:put, path, path_params: path_params, body: body)
    end

    def patch(path, path_params: {}, body: nil)
      request(:patch, path, path_params: path_params, body: body)
    end

    def delete(path, path_params: {})
      request(:delete, path, path_params: path_params)
    end

    def raw_request(method, url)
      token = @auth_client.get_token
      @conn.run_request(method, url, nil, {
        "Authorization" => "Bearer #{token}",
        "Accept" => "application/json"
      })
    end

    def paginate(path, path_params, limit: {{pagination.defaultLimit}})
      Enumerator::Lazy.new(Enumerator.new do |yielder|
        offset = 0
        next_page_url = nil

        loop do
          if next_page_url
            response = raw_request(:get, next_page_url)
          else
            url = build_url(path, path_params)
            response = raw_request(:get, "#{url}?offset=#{offset}&limit=#{limit}")
          end

          data = response.body
          results = data["results"]
          break if results.nil? || results.empty?

          results.each { |item| yielder << item }
          offset += results.length

          paging = data.dig("paging", "nextPage")
          if paging
            next_page_url = paging.start_with?("http") ? paging : "#{@base_url}#{paging}"
          else
            break
          end
        end
      end, :itself)
    end

    # Upload a file using multipart/form-data.
    def upload_file(path, file, path_params: {}, field_name: "file")
      url = build_url(path, path_params)
      token = @auth_client.get_token

      upload_conn = Faraday.new(url: @base_url) do |f|
        f.request :multipart
        f.response :json, content_type: /\bjson$/
      end

      payload = { field_name => Faraday::Multipart::FilePart.new(file, "application/octet-stream") }
      response = upload_conn.post(url, payload, {
        "Authorization" => "Bearer #{token}"
      })

      if response.success?
        return response.status == 204 ? nil : response.body
      end
      raise APIError.from_response(response.status, response.body, nil)
    end

    # Download a file as raw bytes.
    def download_file(path, path_params: {})
      url = build_url(path, path_params)
      token = @auth_client.get_token

      download_conn = Faraday.new(url: @base_url) do |f|
        f.options.timeout = @conn.options.timeout
      end

      response = download_conn.get(url, nil, {
        "Authorization" => "Bearer #{token}"
      })

      if response.success?
        content_type = response.headers["Content-Type"] || "application/octet-stream"
        disposition = response.headers["Content-Disposition"] || ""
        filename = disposition[/filename="?([^";\n]+)"?/, 1]
        { data: response.body, content_type: content_type, filename: filename }
      else
        raise APIError.from_response(response.status, response.body, nil)
      end
    end

    private

    def request(method, path, path_params: {}, query_params: {}, body: nil)
      url = build_url(path, path_params)

      (@max_retries + 1).times do |attempt|
        token = @auth_client.get_token

        response = @conn.run_request(method, url, body, {
          "Authorization" => "Bearer #{token}",
          "Content-Type" => "application/json",
          "Accept" => "application/json"
        }) do |req|
          req.params.merge!(query_params) unless query_params.empty?
        end

        if @log_level != "none"
          @logger.info { "#{method.to_s.upcase} #{url} → #{response.status}" }
          if @log_level == "verbose"
            @logger.debug { "Response Headers: #{response.headers.to_h}" }
            @logger.debug { "Response Body: #{response.body}" }
          end
        end

        if response.success?
          return response.status == 204 ? nil : response.body
        end

        unless RETRY_STATUS_CODES.include?(response.status) && attempt < @max_retries
          raise APIError.from_response(response.status, response.body, response.headers["Retry-After"])
        end

        retry_after = response.headers["Retry-After"]
        delay = if retry_after
                  begin
                    Integer(retry_after)
                  rescue ArgumentError
                    [INITIAL_RETRY_DELAY * (2**attempt) + rand * 0.1, MAX_RETRY_DELAY].min
                  end
                else
                  [INITIAL_RETRY_DELAY * (2**attempt) + rand * 0.1, MAX_RETRY_DELAY].min
                end
        sleep(delay)
      end
    end

    def build_url(path, path_params)
      url = path
      path_params.each { |key, value| url = url.gsub("{#{key}}", CGI.escape(value.to_s)) }
      url
    end
  end
end
