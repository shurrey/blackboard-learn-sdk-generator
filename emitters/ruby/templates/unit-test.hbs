      {{#if (eq (lowercase httpMethod) "get")}}
      resource.{{snakeCase name}}({{#each pathParams}}"test-id"{{#unless @last}}, {{/unless}}{{/each}})
      expect(mock_client).to have_received(:get).once
      {{else if (eq (lowercase httpMethod) "post")}}
      resource.{{snakeCase name}}({{#each pathParams}}"test-id", {{/each}}{{#ifHasBody this}}body: {}{{/ifHasBody}})
      expect(mock_client).to have_received(:post).once
      {{else if (eq (lowercase httpMethod) "put")}}
      resource.{{snakeCase name}}({{#each pathParams}}"test-id", {{/each}}{{#ifHasBody this}}body: {}{{/ifHasBody}})
      expect(mock_client).to have_received(:put).once
      {{else if (eq (lowercase httpMethod) "patch")}}
      resource.{{snakeCase name}}({{#each pathParams}}"test-id", {{/each}}{{#ifHasBody this}}body: {}{{/ifHasBody}})
      expect(mock_client).to have_received(:patch).once
      {{else if (eq (lowercase httpMethod) "delete")}}
      resource.{{snakeCase name}}({{#each pathParams}}"test-id"{{#unless @last}}, {{/unless}}{{/each}})
