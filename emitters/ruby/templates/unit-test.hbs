    allow(mock_client).to receive(:put).and_return({})
    allow(mock_client).to receive(:patch).and_return({})
    allow(mock_client).to receive(:delete).and_return(nil)
  end

{{#each resource.methods}}
  {{#unless paginated}}
  describe "#{{snakeCase name}}" do
