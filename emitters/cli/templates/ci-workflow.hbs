name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '{{langConfig.minGoVersion}}'
      - run: go vet ./...
      - name: Check formatting
        run: test -z "$(gofmt -l .)"

  build:
    name: Build
    runs-on: ubuntu-latest
    strategy:
      matrix:
        goos: [linux, darwin, windows]
        goarch: [amd64, arm64]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '{{langConfig.minGoVersion}}'
      - name: Build
        env:
          GOOS: {{{ghExpr "matrix.goos"}}}
          GOARCH: {{{ghExpr "matrix.goarch"}}}
          CGO_ENABLED: '0'
        run: go build -o {{binaryName}}-{{{ghExpr "matrix.goos"}}}-{{{ghExpr "matrix.goarch"}}} .

  test:
    name: Unit Tests
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '{{langConfig.minGoVersion}}'
      - run: go test ./... -v -count=1

  release:
    name: Release
    runs-on: ubuntu-latest
    needs: [lint, build, test]
    if: startsWith(github.ref, 'refs/tags/')
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/setup-go@v5
        with:
          go-version: '{{langConfig.minGoVersion}}'
      - uses: goreleaser/goreleaser-action@v6
        with:
          version: latest
          args: release --clean
        env:
          GITHUB_TOKEN: {{{ghExpr "secrets.GITHUB_TOKEN"}}}
